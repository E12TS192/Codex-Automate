CODEX_AUTOMATE_DATABASE_URL='postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require'
CODEX_AUTOMATE_WORKSPACE='/srv/codex-automate'
CODEX_AUTOMATE_POLL_SECONDS='5'
CODEX_AUTOMATE_REQUIRE_PERSISTENT_DB='1'
PATH='/Applications/Codex.app/Contents/Resources:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin'
