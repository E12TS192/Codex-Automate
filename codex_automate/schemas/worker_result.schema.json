{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "blocker_reason", "artifacts", "notes"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocker_reason": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "description"],
        "properties": {
          "path": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
