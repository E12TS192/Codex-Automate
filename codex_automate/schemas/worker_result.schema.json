{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "blocker_reason", "artifacts", "notes", "new_packages", "stage_output"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocker_reason": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "description"],
        "properties": {
          "path": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "new_packages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "description",
          "capability",
          "priority",
          "kind",
          "key",
          "depends_on",
          "acceptance_criteria",
          "metadata"
        ],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "capability": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer" },
          "kind": { "type": "string", "minLength": 1 },
          "key": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": false,
            "properties": {}
          }
        }
      }
    },
    "stage_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "key_points",
        "risks",
        "open_questions",
        "components",
        "decisions",
        "delivery_sequence",
        "validation_strategy",
        "handoff",
        "generated_package_titles",
        "generated_package_count"
      ],
      "properties": {
        "verdict": {
          "type": ["string", "null"],
          "enum": ["go", "conditional", "blocked", null]
        },
        "key_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "decisions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "delivery_sequence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_strategy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "handoff": {
          "type": ["string", "null"]
        },
        "generated_package_titles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generated_package_count": {
          "type": "integer"
        }
      }
    }
  }
}
